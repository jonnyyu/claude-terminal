{
  "name": "claude-terminal",
  "version": "1.2.12",
  "description": "Terminal custom pour Claude Code avec gestion des projets, skills et agents",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/build-renderer.js && electron .",
    "start:dev": "node scripts/build-renderer.js && electron . --dev",
    "start:inspect": "node scripts/build-renderer.js && electron . --dev --remote-debugging-port=9222",
    "watch": "node scripts/build-renderer.js --watch",
    "build:renderer": "node scripts/build-renderer.js",
    "build": "node scripts/build-renderer.js && electron-builder --config electron-builder.config.js",
    "build:win": "node scripts/build-renderer.js && electron-builder --win --config electron-builder.config.js",
    "build:mac": "node scripts/build-renderer.js && electron-builder --mac --config electron-builder.config.js",
    "build:linux": "node scripts/build-renderer.js && electron-builder --linux --config electron-builder.config.js",
    "publish": "node scripts/build-renderer.js && electron-builder --win --publish always --config electron-builder.config.js",
    "generate-assets": "node build-assets/generate-installer-images.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "electron-rebuild -f -w node-pty,keytar,better-sqlite3 || echo rebuild skipped"
  },
  "keywords": [
    "claude",
    "terminal",
    "electron"
  ],
  "author": "Yanis",
  "license": "GPL-3.0",
  "homepage": "https://github.com/Sterll/claude-terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sterll/claude-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/Sterll/claude-terminal/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "axe-core": "^4.11.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.2",
    "ffmpeg-static": "^5.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.58.2",
    "sharp": "^0.33.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.158",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^5.0.0",
    "dompurify": "^3.3.1",
    "electron-updater": "^6.1.7",
    "extract-zip": "^2.0.1",
    "form-data": "^4.0.1",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.10.0",
    "katex": "^0.16.38",
    "keytar": "^7.9.0",
    "marked": "^17.0.3",
    "mermaid": "^11.13.0",
    "mongodb": "^6.12.0",
    "mysql2": "^3.11.0",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.5.207",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "three": "^0.183.2",
    "ws": "^8.19.0"
  }
}
